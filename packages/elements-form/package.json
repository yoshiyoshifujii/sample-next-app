{
  "name": "@sample-next-app/elements-form",
  "version": "0.1.0",
  "description": "Stripe Elements payment form component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@stripe/react-stripe-js": ">=2.0.0",
    "@stripe/stripe-js": ">=2.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.1",
    "@types/react": "^19",
    "react": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
